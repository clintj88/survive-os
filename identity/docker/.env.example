# LLDAP Configuration for SURVIVE OS
# Copy this file to .env and update values before running docker-compose

# LLDAP admin credentials
LLDAP_ADMIN_USERNAME=admin
LLDAP_ADMIN_PASSWORD=change-me-in-production

# LLDAP JWT secret (generate with: openssl rand -base64 32)
LLDAP_JWT_SECRET=change-me-generate-random-secret

# LDAP base DN
LLDAP_LDAP_BASE_DN=dc=survive,dc=local

# LLDAP ports
LLDAP_LDAP_PORT=3890
LLDAP_HTTP_PORT=17170

# Data directory (inside container)
LLDAP_DATA_DIR=/data

# Log level: info, debug, warn, error
LLDAP_VERBOSE=false
